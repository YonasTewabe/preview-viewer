VITE_GITHUB_ORG=your-org-name
VITE_API_BASE_URL=http://localhost:4000
VITE_BACKEND_URL=http://localhost:4000/api

# Jenkins integration (backend only)
JENKINS_URL=http://your-jenkins-url
JENKINS_USER=your-jenkins-username
JENKINS_PASSWORD=your-jenkins-password
JENKINS_JOB=your-job-name

# Email configuration (backend only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL="Preview Builder" <noreply@thecubefactory.com>
FRONTEND_URL=http://localhost:3000

# Database configuration (backend only)
DATABASE_URL=your-database-connection-string 