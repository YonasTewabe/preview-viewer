  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:init": "node scripts/initDatabase.js",
    "db:migrate": "npx sequelize-cli --config config/config.cjs --options-path .sequelizerc.cjs --env development db:migrate",
    "db:migrate:undo": "npx sequelize-cli --config config/config.cjs --options-path .sequelizerc.cjs --env development db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli --config config/config.cjs --options-path .sequelizerc.cjs --env development db:migrate:undo:all",
    "db:seed": "npx sequelize-cli --config config/config.cjs --options-path .sequelizerc.cjs db:seed:all",
    "db:seed:undo": "npx sequelize-cli --config config/config.cjs --options-path .sequelizerc.cjs db:seed:undo:all",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:password-reset": "node test-password-reset.js"
  },
